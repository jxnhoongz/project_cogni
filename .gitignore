# Environment
.env
.env.local

# Credentials
credentials/*
!credentials/.gitkeep
!credentials/README.md

# Per-book projects (generated + user content — book text may be copyrighted)
/projects/
/.active_project

# Shared background music (drop your own in; not committed)
assets/audio/*
!assets/audio/.gitkeep
data/videos/*
!data/videos/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
/scenes_*.json

# Scratch + generated Remotion assets (regenerable, per-book)
/scratchpad/
/remotion/public/

# Source books (PDF/EPUB) — large, and not ours to redistribute
sources/
