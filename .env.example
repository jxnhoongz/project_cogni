# OpenRouter — used ONLY for image generation (config image.provider: openrouter).
# Claude models (ingest, script) run on the local `claude` CLI / your Claude
# subscription, so they need no key here.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# NOTE: Higgsfield "hero" clips are produced OUTSIDE this repo via its MCP.
# It is NOT a pipeline dependency — no key needed here.
