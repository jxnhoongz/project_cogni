# OpenRouter — all LLM calls (script generation, ingest, Khmer via Gemini) route here.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Image provider — the still-image generator. Name the var after the provider you wire
# into generate_image() (e.g. OPENAI_API_KEY for DALL-E, or a Replicate/other key).
# Rename this to match your provider; the images stage reads it.
IMAGE_PROVIDER_API_KEY=your-key-here

# NOTE: Higgsfield "hero" clips are produced OUTSIDE this repo via its MCP.
# It is NOT a pipeline dependency — no key needed here.
